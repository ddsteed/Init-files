#!/usr/bin/env zsh
#-----------------------------------------------------------------------
# Multipass Ubuntu 虚拟机管理
#
# 功能说明：
#   - 管理 Ubuntu 虚拟机实例
#   - 快速启动/连接/挂载目录
#
# 作者：     Hao Feng (F1)
# 版权：     (c) 2022, RDS
# 创建日期：Aug. 29, 2024
# 最后更新：Mar. 20, 2025
#
# 版本历史：
#   v1.0.0 (2024-08-29) - 初始版本
#   v1.1.0 (2025-03-20) - 添加完整的中文注释和版本历史
#-----------------------------------------------------------------------

image=24.04  # Ubuntu 镜像版本：20.04 / 22.04 / 24.04

# 预定义虚拟机 IP 地址
u22=192.168.64.22
u24=192.168.10.27

# 当前使用的虚拟机配置
name=u24
ubuntu=$u24

#-----------------------------------------------------------------------
# 函数：mln
# 功能：启动新的 Multipass 虚拟机
# 参数：无（使用 $name 和 $image）
# 配置：4核 CPU / 8GB 内存 / 50GB 磁盘
#-----------------------------------------------------------------------
mln () {
  multipass launch $image --name $name -c 4 -m 8G -d 50G
}

#-----------------------------------------------------------------------
# 函数：shm
# 功能：通过 SSH 连接到虚拟机（支持 X11 转发）
#-----------------------------------------------------------------------
shm () {
  ssh -X -Y f1@$ubuntu
}

#-----------------------------------------------------------------------
# 函数：ms
# 功能：进入虚拟机 Shell
#-----------------------------------------------------------------------
ms () {
  multipass shell $name
}

#-----------------------------------------------------------------------
# 函数：mstop
# 功能：停止虚拟机
#-----------------------------------------------------------------------
mstop () {
  multipass stop $name
}

#-----------------------------------------------------------------------
# 函数：mst
# 功能：启动虚拟机
#-----------------------------------------------------------------------
mst () {
  multipass start $name
}

#-----------------------------------------------------------------------
# 函数：mrs
# 功能：重启虚拟机
#-----------------------------------------------------------------------
mrs () {
  multipass restart $name
}

#-----------------------------------------------------------------------
# 函数：min
# 功能：显示虚拟机详细信息
#-----------------------------------------------------------------------
min () {
  multipass info $name
}

#-----------------------------------------------------------------------
# 别名：快速命令
#-----------------------------------------------------------------------
alias mls='multipass ls'     # 列出所有虚拟机
alias mf='multipass find'    # 查找可用镜像

#-----------------------------------------------------------------------
# 函数：mm
# 功能：挂载本地目录到虚拟机
# 参数：$1=本地路径 $2=虚拟机路径
#-----------------------------------------------------------------------
mm () {
    multipass mount $1 $2
}

#-----------------------------------------------------------------------
# 函数：mfengh
# 功能：挂载用户主目录到虚拟机
#-----------------------------------------------------------------------
mfengh () {
  mm /Users/fengh $name:/Users/fengh
}
