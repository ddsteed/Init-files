#-----------------------------------------------------------------------
# 环境映射说明
#-----------------------------------------------------------------------
#   ai:       AI 环境
#   dcmenv:   DCM Conda 环境
#   fpa:      Fatavay Physics based AI
#   kgai:     Knowledge Graph AI
#   llm:      Large Language Model
#   mapms:    Multi Agent Project Management System
#   mforge:   Miniforge
#   mconda:   Miniconda（禁止手动更新！！！）
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 函数：create_conda
# 功能：创建新的 Conda 环境
# 参数：$1=环境路径
#-----------------------------------------------------------------------
create_conda () {
    name=$1

    if [[ ! -f $name ]]; then
        # 获取系统 Python 版本
        py_version=$(python3 --version | awk '{print $2}')
        version=$(echo ${py_version%.*})
        conda create -y -p $name python=$version conda
    fi

    conda activate $name
    conda config --env --add channels conda-forge
}

#-----------------------------------------------------------------------
# 函数：init_conda
# 功能：初始化 Conda 环境
# 参数：$1=环境路径
#-----------------------------------------------------------------------
init_conda () {
    env=$1

    # 尝试通过 conda.sh 激活
    if [[ -f $env/etc/profile.d/conda.sh ]]; then
        source $env/etc/profile.d/conda.sh
        conda activate $env
    # 尝试通过 activate 激活（virtualenv）
    elif [[ -f $env/bin/activate ]]; then
        source $env/bin/activate
    else
        # 初始化并创建环境
        conda init zsh >& /dev/null
        conda activate $env
        if [ $? -ne 0 ]; then
            echo
            echo "$env does NOT exist, create it firstly."
            echo "----------------------------------------------------"
            echo
            create_conda $env
        fi
    fi

    # 获取 pip bin 目录
    condabin=$(which pip3 | xargs dirname)
}

#-----------------------------------------------------------------------
# 函数：pipup
# 功能：交互式更新所有 Python 包
#-----------------------------------------------------------------------
pipup () {
    pip-review -a
}

#-----------------------------------------------------------------------
# 函数：condauc
# 功能：Conda 更新/清理（通用）
# 参数：$1=子命令（update/clean）
#-----------------------------------------------------------------------
condauc () {
    conda $1 --all -y
}

#-----------------------------------------------------------------------
# 函数：condaup
# 功能：更新所有 Conda 包
#-----------------------------------------------------------------------
condaup () {
    condauc update
}

#-----------------------------------------------------------------------
# 函数：condaclean
# 功能：清理 Conda 缓存
#-----------------------------------------------------------------------
condaclean () {
    condauc clean
}

#-----------------------------------------------------------------------
# 函数：acondaup
# 功能：更新 Anaconda
#-----------------------------------------------------------------------
acondaup () {
    conda update anaconda --all -y
}

#-----------------------------------------------------------------------
# 函数：conda_export
# 功能：导出 Conda 环境到文件
# 参数：$1=输出文件名
#-----------------------------------------------------------------------
conda_export () {
    conda env export --no-builds | grep -v "^prefix: " > $1
}

#-----------------------------------------------------------------------
# 函数：conda_from_file
# 功能：从文件创建 Conda 环境
# 参数：$1=环境文件名
#-----------------------------------------------------------------------
conda_from_file () {
    mamba env update --file $1
}

#-----------------------------------------------------------------------
# 函数：cdea
# 功能：停用当前 Conda 环境
#-----------------------------------------------------------------------
cdea () {
    conda deactivate
}

#-----------------------------------------------------------------------
# 函数：cact
# 功能：激活指定 Conda 环境
# 参数：$1=环境名称
#-----------------------------------------------------------------------
cact () {
    conda activate $1
}

#-----------------------------------------------------------------------
# 函数：cinfo
# 功能：显示 Conda 信息
#-----------------------------------------------------------------------
cinfo () {
    conda info
}

#-----------------------------------------------------------------------
# 函数：cel
# 功能：列出所有 Conda 环境
#-----------------------------------------------------------------------
cel () {
    conda env list
}

#-----------------------------------------------------------------------
# 函数：jnb
# 功能：启动 Jupyter Notebook
#-----------------------------------------------------------------------
jnb () {
    $condabin/jupyter-notebook
}

#-----------------------------------------------------------------------
# 函数：jlab
# 功能：启动 Jupyter Lab
#-----------------------------------------------------------------------
jlab () {
    $condabin/jupyter-lab
}

#-----------------------------------------------------------------------
# 函数：install_conda_basic
# 功能：安装基础数据科学包
#-----------------------------------------------------------------------
install_conda_basic () {
    basic=(jupyter matplotlib numpy pandas scipy seaborn)
    mamba install -y -c conda-forge ${basic[@]}
}

#-----------------------------------------------------------------------
# 函数：pyenv
# 功能：创建 Python virtualenv
# 参数：$1=环境路径
#-----------------------------------------------------------------------
pyenv () {
    python3 -m venv $1
}

#-----------------------------------------------------------------------
# 主程序：根据调用名称设置环境
#-----------------------------------------------------------------------

runname=$(basename $0)
os=$(uname)

# 项目环境路径配置
ai_home=~/Research/AI/AI
dcm_home=~/Research/FORECAST/DCM
fpa_home=~/Research/AI/FPA/FPA
llm_home=~/Research/AI/LLM
mapms_home=~/Research/Fatavay/MAPMS
kgai_home=~/Research/AI/kgai
mf_home=/opt/Homebrew/Caskroom/miniforge/base
mc_home=/opt/Homebrew/Caskroom/miniconda/base

case $runname in
    ai | aiconda)
        export condaenv=${ai_home}/envs
        export conda_name=ai
        ;;
    fpa)
        export condaenv=${fpa_home}/envs
        export conda_name=fpa
        ;;
    dcmenv)
        export condaenv=${dcm_home}/envs
        export conda_name=dcmenv
        ;;
    kgai)
        export condaenv=${kgai_home}/envs
        export conda_name=kgai
        ;;
    llm)
        export condaenv=${llm_home}/envs
        export conda_name=llm
        ;;
    mapms)
        export condaenv=${mapms_home}/envs
        export conda_name=mapms
        ;;
    mforge)
        export condaenv=${mf_home}
        export conda_name=mforge
        ;;
    mconda)
        export condaenv=${mc_home}
        export conda_name=mconda
        ;;
    *)
        export condaenv=${mc_home}
        export conda_name=mconda
        ;;
esac

# 添加 bin 到 PATH 并初始化环境
export PATH=${condaenv}/bin:$PATH
init_conda $condaenv
