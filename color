#!/usr/bin/env zsh
#-----------------------------------------------------------------------
# 彩色命令行工具别名配置
#
# 功能说明：
#   - 配置现代化终端工具的彩色别名
#   - 替代传统 Unix 工具，提供更好的可读性
#
# 作者：     Hao Feng (F1)
# 版权：     (c) 2022, RDS
# 创建日期：Aug. 1, 2025
# 最后更新：Mar. 20, 2025
#
# 版本历史：
#   v1.0.0 (2022-08-01) - 初始版本
#   v1.1.0 (2025-03-20) - 添加完整的中文注释和版本历史
#-----------------------------------------------------------------------

runname=$(basename $0)

#-----------------------------------------------------------------------
# eza: ls 命令的替代品，彩色输出目录内容，更容易辨识
#-----------------------------------------------------------------------
alias ll='eza --long --git'       # 详细列表 + Git 状态
alias lla='eza --all --long --git' # 显示所有文件（包括隐藏文件）
alias ll2='eza --tree --level=2'   # 显示两层目录树

#-----------------------------------------------------------------------
# broot: 终端文件管理器，增强版 ls
#-----------------------------------------------------------------------
alias br='broot -sdph'  # 显示隐藏文件、权限、大小

#-----------------------------------------------------------------------
# bat: cat 命令的替代品，带语法高亮和行号
#-----------------------------------------------------------------------
alias bt='bat'

#-----------------------------------------------------------------------
# fd: find 命令的替代品，用于文件名搜索
# 用法：fd dog /tmp
#-----------------------------------------------------------------------
alias fid='fd'

#-----------------------------------------------------------------------
# ripgrep: grep 命令的替代品，搜索文件内容
# 用法：rg foo *.md
#-----------------------------------------------------------------------
alias rgp='rg'

#-----------------------------------------------------------------------
# duf: df 命令的替代品，显示磁盘占用情况
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# ncdu: du 命令的替代品，交互式磁盘使用分析
#-----------------------------------------------------------------------
alias duh='ncdu --color dark'

#-----------------------------------------------------------------------
# htop: top 命令的替代品，显示系统实时状态
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# procs: ps 命令的替代品，高亮显示进程信息
#-----------------------------------------------------------------------
alias pcs='procs'

#-----------------------------------------------------------------------
# httpie: curl 的替代品，友好的 HTTP 请求工具
# 用法：http PUT example.com hello=world
#-----------------------------------------------------------------------
