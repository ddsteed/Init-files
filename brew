#-----------------------------------------------------------------------
# 函数：brewtap
# 功能：批量添加/移除第三方 tap 源
# 参数：
#   $1 - 操作类型：
#        u  - 移除（untap）
#        无 - 添加（tap，默认）
# 用法：
#   brewtap       # 添加所有第三方源
#   brewtap u     # 移除所有第三方源
#-----------------------------------------------------------------------
brewtap() {
    # 参数默认值处理（满足 shellcheck SC2120）
    local action="${1:-}"

    # 常用第三方源列表（注意：不使用行内注释，避免循环时被分割）
    local -a taps=(
        langgenius/dify
        beeftornado/rmtree
        mongodb/brew
        felixkratz/formulae
        jsattler/tap
    )

    # 确定操作类型
    local operation="tap"
    local operation_name="添加"
    if [[ "$action" == "u" ]]; then
        operation="untap"
        operation_name="移除"
    fi

    echo "开始${operation_name}第三方 tap 源..."
    echo "----------------------------"

    local success_count=0
    local failed_count=0
    local skipped_count=0

    for tap_repo in "${taps[@]}"; do
        echo -n "[$tap_repo] ... "

        # 根据操作类型执行命令，静默处理已存在的情况
        if brew "$operation" "$tap_repo" &>/dev/null; then
            echo "✓"
            ((success_count++))
        elif brew "$operation" "$tap_repo" 2>&1 | grep -q "already tapped"; then
            echo "⊘ 已存在"
            ((skipped_count++))
        else
            echo "✗ 失败"
            ((failed_count++))
        fi
    done

    echo "----------------------------"
    echo "完成: 成功=$success_count, 跳过=$skipped_count, 失败=$failed_count"
}

