#- brew 安装常用的软件
# 添加第三方库

brewtap () {
    taps=(langgenius/dify beeftornado/rmtree mongodb/brew felixkratz/formulae)

    case $1 in
        u)
            run=untap
            ;;
        *)
            run=tap
            ;;
    esac

    for ap in $taps; do
        brew $run $ap
    done
 }

