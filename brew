runname=$(basename $0)

#-----------------------------------------------------------------------
# 函数：brewup
# 功能：更新/升级所有 HomeBrew 应用
# 流程：
#   1. 更新 HomeBrew 本体
#   2. 升级所有 formula（命令行工具）
#   3. 升级所有 cask（图形应用）
#   4. 升级 Mac App Store 应用（已禁用）
#-----------------------------------------------------------------------
brewup() {
    # 更新 HomeBrew 本体
    echo
    echo "更新 HomeBrew ..."
    echo "----------------------------"
    brew update

    # 升级所有命令行工具
    echo
    echo "升级所有命令行应用 ... "
    echo "----------------------------"
    brew upgrade

    # 升级所有图形应用（包括版本号不变的）
    echo
    echo "升级所有图形应用 ... "
    echo "----------------------------"
    brew upgrade --cask --greedy

    # 升级 Mac App Store 应用（当前已禁用）
    # echo
    # echo "升级 Mac App Store 应用 ... "
    # echo "----------------------------"
    # /opt/homebrew/bin/mas upgrade
}

#-----------------------------------------------------------------------
# 函数：bin
# 功能：安装指定应用
# 参数：
#   $1 - 应用名称
#   $2 - 类型：cask/c（图形应用）或 默认（命令行工具）
# 用法：
#   bin curl          # 安装命令行工具 curl
#   bin chrome c      # 安装图形应用 Chrome
#-----------------------------------------------------------------------
bin() {
    opt=
    # 判断是否为 cask 应用
    if [[ $2 == "cask" || $2 == "c" ]]; then
        opt="--cask"
    else
        opt="--force-bottle"
    fi

    brew install $1 -v --force $opt
}

#-----------------------------------------------------------------------
# 函数：brin
# 功能：重新安装指定应用
# 参数：
#   $1 - 应用名称
#   $2 - 类型：cask/c（图形应用）或 默认（命令行工具）
# 用法：
#   brin curl         # 重装命令行工具 curl
#   brin chrome c     # 重装图形应用 Chrome
#-----------------------------------------------------------------------
brin() {
    opt=
    if [[ $2 == "cask" || $2 == "c" ]]; then
        opt="--cask"
    fi

    brew reinstall $1 -v --force $opt
}

#-----------------------------------------------------------------------
# 函数：bup
# 功能：升级指定应用
# 参数：$1 - 应用名称
# 用法：bup curl
#-----------------------------------------------------------------------
bup() {
    brew upgrade $1 -v
}

#-----------------------------------------------------------------------
# 函数：buni
# 功能：卸载指定应用
# 参数：$1 - 应用名称
# 用法：buni curl
#-----------------------------------------------------------------------
buni() {
    brew uninstall $1 -v
    # 依赖清理已改用 brew rmtree
}

#-----------------------------------------------------------------------
# 函数：brm
# 功能：完全卸载应用及其所有依赖
# 参数：$1 - 应用名称
# 用法：brm curl
# 说明：需要安装 beeftornado/rmtree tap
#-----------------------------------------------------------------------
brm() {
    brew rmtree $1
}

#-----------------------------------------------------------------------
# 函数：brewbk
# 功能：备份所有已安装应用到 Brewfile
# 输出：~/.backup/Brewfile
# 用法：brewbk
#-----------------------------------------------------------------------
brewbk() {
    echo "备份已安装的 Brew 应用 ... "
    echo "----------------"
    echo
    brew bundle dump --file=~/.backup/Brewfile -f
}

#-----------------------------------------------------------------------
# 函数：brewrt
# 功能：从 Brewfile 恢复所有应用
# 输入：~/.backup/Brewfile
# 用法：brewrt
#-----------------------------------------------------------------------
brewrt() {
    echo "从备份恢复 Brew 应用 ... "
    echo "-----------------"
    echo
    brew bundle --file=~/.backup/Brewfile --force
}

#-----------------------------------------------------------------------
# HomeBrew 系统级操作
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 函数：brewinstall
# 功能：安装 HomeBrew 到系统
# 用法：brewinstall
#-----------------------------------------------------------------------
brewinstall() {
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

#-----------------------------------------------------------------------
# 函数：brewuninstall
# 功能：完全卸载 HomeBrew
# 用法：brewuninstall
#-----------------------------------------------------------------------
brewuninstall() {
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/uninstall.sh)"
}

#-----------------------------------------------------------------------
# 函数：brewrm
# 功能：批量卸载指定类型的所有应用
# 参数：$1 - 类型（formula/cask）
# 用法：brewrm formula
#-----------------------------------------------------------------------
brewrm() {
    brew ls --$1 | xargs brew remove -f --ignore-dependencies
}

#-----------------------------------------------------------------------
# 函数：brewreset
# 功能：重置 HomeBrew 源（官方/国内镜像）
# 参数：
#   $1 - 镜像源：
#        ustc     - 中国科学技术大学镜像
#        official - 官方源（默认）
# 用法：
#   brewreset ustc      # 切换到中科大镜像
#   brewreset official  # 切换到官方源
#-----------------------------------------------------------------------
brewreset() {
    unset HOMEBREW_BREW_GIT_REMOTE
    rm ~/.zprofile

    case $1 in
        ustc)
            # 中科大镜像源
            git -C "$(brew --repo)" remote set-url origin https://mirrors.ustc.edu.cn/brew.git
            echo 'export HOMEBREW_BREW_GIT_REMOTE="https://mirrors.ustc.edu.cn/brew.git"' >! ~/.zprofile
            echo 'export HOMEBREW_API_DOMAIN="https://mirrors.ustc.edu.cn/homebrew-bottles/api"' >> ~/.zprofile
            echo 'export HOMEBREW_BOTTLE_DOMAIN="https://mirrors.ustc.edu.cn/homebrew-bottles/bottles"' >> ~/.zprofile
            ;;
        official | *)
            # GitHub 官方源
            git -C "$(brew --repo)" remote set-url origin https://github.com/Homebrew/brew
            ;;
    esac

    echo 'eval "$(/opt/homebrew/bin/brew shellenv)" ' >> ~/.zprofile
}

#-----------------------------------------------------------------------
# 第三方库管理
