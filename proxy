#!/usr/bin/env bash
#-----------------------------------------------------------------------
# 系统代理配置脚本
#
# 功能说明：
#   - 自动设置 HTTP/HTTPS 代理环境变量
#   - 支持 macOS 和 Linux 不同配置
#
# 作者：     Hao Feng (F1)
# 版权：     (c) 2022, RDS
# 创建日期：Nov. 13, 2024
# 最后更新：Mar. 20, 2025
#
# 版本历史：
#   v1.0.0 (2024-11-13) - 初始版本
#   v1.1.0 (2025-03-20) - 添加完整的中文注释和版本历史
#-----------------------------------------------------------------------

os=$(uname)
ip0='192.168.65.1'  # 默认 Linux 代理服务器 IP

case $os in
    Darwin)
        # macOS 配置：使用本地代理
        export https_proxy="http://127.0.0.1:7897"
        export http_proxy="http://127.0.0.1:7897"
        ;;
    Linux)
        # Linux 配置：使用远程代理
        # 如果没有指定第二个参数，使用默认 IP
        if [ ! -n "$2" ] ;then
            ip=$ip0
        else
            ip=$2
        fi
        echo "proxy ip = $ip"
        export https_proxy=$ip:10001
        export http_proxy=$ip:10001
        ;;
esac
