#!/usr/bin/env zsh
#-----------------------------------------------------------------------
# 文档格式转换脚本
#
# 功能说明：
#   - eBook 格式转换（docx/md/pdf/epub）
#   - OCR 文字识别（pdf/png）
#   - 基于 Pandoc 和 Tesseract
#
# 作者：     Hao Feng (F1)
# 版权：     (c) 2022, RDS
# 创建日期：Jun. 13, 2022
# 最后更新：Mar. 20, 2025
#
# 版本历史：
#   v1.0.0 (2022-06-13) - 初始版本
#   v1.1.0 (2025-03-20) - 添加完整的中文注释和版本历史
#-----------------------------------------------------------------------

runname=$(basename $0)

case $runname in
    ebook)
        #-----------------------------------------------------------------------
        # eBook 转换函数集
        #-----------------------------------------------------------------------

        # Docx 转 Markdown
        d2m () {
            pandoc -f docx -t markdown --extract-media=$1 -o $1.md $1.docx
        }

        # Markdown 转 Docx
        m2d () {
            pandoc $1.md -o $1.docx
        }

        # Markdown 转 PDF（带目录、页码、彩色链接）
        m2p () {
            pandoc --pdf-engine=xelatex \
                   --toc -N \
                   -V colorlinks -V urlcolor=NavyBlue \
                   --highlight-style zenburn \
                   $1.md -o $1.pdf
        }

        # Markdown 转 EPUB
        m2e () {
            pandoc -s --toc --toc-depth=2 $1.md -o $1.epub
        }

        # PNG 转 PDF
        p2p () {
            sips -s format pdf $1.png --out $1.pdf
        }
        ;;
    w2m)
        # Wiki to Markdown（Ruby 环境）
        eval "$(rbenv init -)"

        export PATH="/opt/homebrew/lib/ruby/gems/3.0.0/bin:/opt/homebrew/opt/ruby/bin:$PATH"
        export LDFLAGS="-L/opt/homebrew/opt/ruby/lib"
        export CPPFLAGS="-I/opt/homebrew/opt/ruby/include"
        export PKG_CONFIG_PATH="/opt/homebrew/opt/ruby/lib/pkgconfig"
        ;;
    ocr)
        # OCR 环境初始化
        source ~/Init/abrew
        ;;
    *)
        # 默认
        ;;
esac

#-----------------------------------------------------------------------
# 函数：pdfocr
# 功能：PDF 文档 OCR（旧方法，使用 ImageMagick + Tesseract）
# 参数：$1=文件名（不含扩展名）
# 流程：PDF → TIFF → OCR → 合并 PDF
#-----------------------------------------------------------------------
pdfocr () {
    name=$1

    # 分割 PDF 并转换为 TIFF（300 DPI，灰度）
    convert -density 300 $name.pdf -type Grayscale -compress lzw -background white +matte -depth 32 page_%05d.tif

    # 对每页进行 OCR
    for i in page_*.tif; do echo $i; tesseract $i $(basename $i .tif) pdf; done

    # 合并所有 OCR 后的 PDF
    pdftk page_*.pdf cat output ${name}_merged.pdf
}

#-----------------------------------------------------------------------
# 函数：ocrpdf
# 功能：PDF 文档 OCR（新方法，使用 ocrmypdf）
# 参数：
#   -l 语言代码（默认：eng+chi_sim）
#   -i 输入文件名（默认：input）
#   -o 输出文件名（默认：input_o）
#   -f 输出格式（默认：pdf）
# 用例：ocrpdf -i document -l eng+chi_sim
#-----------------------------------------------------------------------
ocrpdf () {
    source ~/Init/abrew

    # 参数解析
    while test "x$1" != "x"; do
        case $1 in
            -l) shift; lang=$1      ;;
            -i) shift; inpu=$1      ;;
            -o) shift; oupt=$1      ;;
            -f) shift; ofmt=$1      ;;
            *)                      ;;
        esac
        shift
    done

    # 默认值设置
    if [[ $lang == ""   ]]; then lang=eng+chi_sim;  fi
    if [[ $inpu == ""   ]]; then inpu=input;        fi
    if [[ $oupt == ""   ]]; then oupt=${inpu}_o;    fi
    if [[ $ofmt == ""   ]]; then ofmt=pdf;          fi

    # 执行 OCR
    ocrmypdf -l $lang --output-type $ofmt $inpu.pdf $oupt.pdf
}

#-----------------------------------------------------------------------
# 函数：ocrpng
# 功能：PNG 图片 OCR
# 参数：$1=文件名（不含扩展名）
#-----------------------------------------------------------------------
ocrpng () {
    sips -s format pdf $1.png --out $1.pdf
    ocrpdf -i $1
}

#-----------------------------------------------------------------------
# 函数：ocr
# 功能：通用 OCR 入口（自动检测文件类型）
# 参数：$1=完整文件名（含扩展名）
#-----------------------------------------------------------------------
ocr () {
    name=(`get_suffix $1`)
    prefix=${name[1]}
    suffix=${name[2]}

    case $suffix in
        pdf)
            ocrpdf $prefix
            ;;
        png)
            ocrpng $prefix
            ;;
    esac
}
