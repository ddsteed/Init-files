#!/usr/bin/env zsh
#-----------------------------------------------------------------------
# 系统软件统一更新脚本
#
# 功能说明：
#   - 一键更新 macOS/Linux 系统和所有软件
#   - 支持 Homebrew、Conda、MacTeX、APT 等多种包管理器
#   - 彩色输出，进度显示
#
# 作者：     Hao Feng (F1)
# 版权：     (c) 2022, RDS
# 创建日期：Mar. 13, 2022
# 最后更新：Apr. 01, 2023
#
# 版本历史：
#   v1.0.0 (2022-03-13) - 初始版本
#   v1.1.0 (2022-06-27) - 新增 Conda 环境支持
#   v1.2.0 (2023-04-01) - 新增彩色输出
#   v1.3.0 (2025-03-20) - 添加完整的中文注释和版本历史
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 参数说明：
#   由于 'update' 通常通过 'ini update' 调用，参数位置为 $2
#   直接调用 'update' 时，应将 $2 改为 $1
#-----------------------------------------------------------------------

# 确定要更新的组件列表
if [[ $2 == "" ]]; then
    if [[ $(uname) == "Darwin" ]]; then
        # macOS 默认更新列表
        update=(mac brew)
    elif [[ $(uname) == "Linux" ]]; then
        # Linux 默认更新列表
        update=(apt)
    fi
else
    update=($2)
fi

#-----------------------------------------------------------------------
# 函数：echoline
# 功能：输出分隔线
#-----------------------------------------------------------------------
echoline () {
    echo "--------------------------------------------------"
}

#-----------------------------------------------------------------------
# 函数：printc_d
# 功能：输出蓝色背景文字
#-----------------------------------------------------------------------
function printc_d {
    bg=44
    fg=37
    txt=$1
    echo -e "\033[${bg};${fg}m${txt}\033[0m"
}

#-----------------------------------------------------------------------
# 函数：print_welcome
# 功能：显示欢迎信息
#-----------------------------------------------------------------------
function print_welcome () {
    printc_d "-----------------------------------------------------"
    printc_d " This script is to update all Mac/Linux Softwares    "
    printc_d "                                                     "
    printc_d " Author: Hao Feng (F1)                               "
    printc_d "                                                     "
    printc_d " Copyright (c) 2022, RDS                             "
    printc_d "                                                     "
    printc_d "-----------------------------------------------------"
    echo
    echo     "  The following packages will be updated ...      "
    echo
    echo     "   ${update[@]} "
    echo
    printc_d "-----------------------------------------------------"
}

# 显示欢迎信息
print_welcome

num=0
total=${#update[@]}

#-----------------------------------------------------------------------
# 主更新循环
#-----------------------------------------------------------------------
for mission in ${update[@]}; do
    let num++
    echo
    printc_d "[$num/$total]: $mission  "

    case $mission in
        mac)
            # 更新 macOS 系统软件
            printc_d " Updating Mac OS system & softwares ... "
            echo

            softwareupdate --all --install --force
           ;;

        *brew*)
            # 更新 Homebrew 应用
            source  ~/Init/$mission
            printc_d " Updating Homebrew ($mission) applications ... "
            echo
            echo     "   *  BREW HOME: $HOMEBREW_REPOSITORY"
            echo

            brewup

            echo
            echo "Clean up all brew caches ..."
            echo "----------------------------"
            brew cleanup
            ;;

        # Conda 环境更新
        *forge | ai | bd | dcm* | *conda* | cloud | llm)
            source ~/Init/$mission

            printc_d " Updating $condaenv ... "
            echo

            condaup
            if [[ $mission == aconda ]]; then acondaup; fi
            condaclean
            ;;

        apt)
            # 更新 Ubuntu Linux APT 软件
            printc_d " Updating Ubuntu Linux apt softwares ... "
            echo

            sudo apt-get update -y && sudo apt-get upgrade -y
            sudo apt-get autoremove -y
            ;;

        mactex)
            # 更新 MacTeX
            source  ~/Init/$mission
            printc_d " Updating MacTex ... "
            echo

            tex_update
            ;;

        *)
            # 未知组件
            printc_d " $mission is NOT in the update lists ..."
            echo
            ;;
    esac
done
