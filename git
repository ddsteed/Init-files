        bakrepo=(bak)
        ;;
esac

#-----------------------------------------------------------------------
# 函数：fgit
# 功能：多仓库/多分支批量 Git 操作
# 参数：$1=操作(pull/push/fetch) $2=仓库列表 $3=分支列表 $4=force 选项
# 用法：
#   fgit pull              # 拉取所有仓库所有分支
#   fgit push github1 dev  # 推送到 github1 的 dev 分支
#-----------------------------------------------------------------------
fgit () {
    # 解析操作类型
    if [[ "x$1" != "x" ]]; then
        run=$1; shift
    else
        run=pull
    fi

    # 解析仓库列表
    if [[ "x$1" != "x" ]]; then
        repo=($1); shift
    else
        repo=($repository[@])
    fi

    # 解析分支列表
    if [[ "x$1" != "x" ]]; then
        bran=($1); shift
    else
        bran=($branch[@])
    fi

    # 解析 force 选项
    if [[ "x$1" != "x" ]]; then
        force="--$1"; shift
    else
        force=
    fi

    echo
    echo "* Git $run --- "
    echo "      repo = ${repo[@]}: ${#repo[*]}"
    echo "      bran = ${bran[@]}: ${#bran[*]}"

    mission=0
    total=$[ ${#repo[@]} * ${#bran[@]} ]

    # 遍历所有仓库和分支
    for re in ${repo[@]}; do
        for br in ${bran[@]}; do
            let mission++
            echo
            echo "----------------------------------------------------"
            echo " [$mission/$total]: "
            echo "         $run repository: $re/$br ... "
            echo "         ****             *************** "
            echo
            git $run $re $br $force --tags
        done
    done

    echo "----------------------------------------------------"
}

#-----------------------------------------------------------------------
# 函数：fpush
# 功能：批量推送到所有仓库的所有分支
# 参数：$1=force 选项（可选）
#-----------------------------------------------------------------------
fpush () {
    if [[ "x$1" != "x" ]]; then
        fr=$1; shift
    else
        fr=
    fi

    for re in ${repository[@]}; do
        for br in ${branch[@]}; do
            fgit push $re $br $fr
        done
    done
}

#-----------------------------------------------------------------------
# 函数：fpull
# 功能：从所有仓库拉取更新
#-----------------------------------------------------------------------
fpull () {
    for re in ${repository[@]}; do
        fgit pull $re
    done
}

#-----------------------------------------------------------------------
# 函数：ffetch
# 功能：从所有仓库获取更新（不合并）
#-----------------------------------------------------------------------
ffetch () {
    for re in ${repository[@]}; do
        fgit fetch $re
    done
}

#-----------------------------------------------------------------------
# 函数：fbak
# 功能：备份仓库操作
# 参数：$1=操作（push/pull，默认 push）
#-----------------------------------------------------------------------
fbak () {
    if [[ $1 == "" ]]; then
        run=push
    else
        run=$1; shift
    fi

    for re in ${bakrepo[@]}; do
        fgit $run $re
    done
}

#-----------------------------------------------------------------------
# 函数：gck
# 功能：智能切换 Git 分支
# 参数：$1=分支名
# 说明：分支存在则切换，不存在则创建
#-----------------------------------------------------------------------
gck () {
    if [[ `git branch --list $1` ]]; then
        git switch $1
    else
        git switch -c $1
    fi
}

