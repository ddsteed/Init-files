#-----------------------------------------------------------------------
# 函数：gcom
# 功能：快速提交（添加所有文件并提交）
# 参数：$1=提交信息
#-----------------------------------------------------------------------
gcom () {
    git add .
    git commit -a -m "$1"
}

#-----------------------------------------------------------------------
# 函数：gtmp
# 功能：临时提交（使用当前时间作为提交信息）
#-----------------------------------------------------------------------
gtmp () {
    gcom "update on `date` "
}

#-----------------------------------------------------------------------
# 函数：gpush
# 功能：推送到 github（带标签）
#-----------------------------------------------------------------------
gpush () {
    git push github --follow-tags
}

#-----------------------------------------------------------------------
# 函数：fatpush
# 功能：推送到 Fatavay 仓库（强制推送）
# 参数：$1=仓库编号
#-----------------------------------------------------------------------
fatpush () {
    echo "push fat$1 ..."
    git push fat$1 develop --force --follow-tags
}

#-----------------------------------------------------------------------
# 函数：gpull
# 功能：从 github 拉取 develop 分支
#-----------------------------------------------------------------------
gpull () {
    git pull github develop
}

#-----------------------------------------------------------------------
# 函数：gfat
# 功能：推送到 Fatavay 仓库
# 参数：$1=仓库编号
#-----------------------------------------------------------------------
gfat () {
    git push fat$1
}

#-----------------------------------------------------------------------
# 函数：gl10
# 功能：列出仓库中最大的 10 个文件
#-----------------------------------------------------------------------
gl10 () {
    git rev-list --all | xargs -rL1 git ls-tree -r --long | sort -uk3 | sort -rnk4 | head -10
}

#-----------------------------------------------------------------------
# 函数：glarge
# 功能：列出仓库中最大的 N 个文件
# 参数：$1=数量
#-----------------------------------------------------------------------
glarge () {
  git rev-list --all | xargs -rL1 git ls-tree -r --long | sort -uk3 | sort -rnk4 | head -$1
}

#-----------------------------------------------------------------------
# 函数：grmt
# 功能：彻底删除文件（包括历史记录）
# 参数：$1=文件路径
# 警告：此操作不可逆，会重写 Git 历史！
#-----------------------------------------------------------------------
grmt () {
    echo "delete file/directory thoroughly, so be carefully doing it!!!"
    echo -n " * please input yes/no: "
    read continue
    if [[ $continue == "yes" ]]; then
        # 使用 filter-branch 删除历史记录
        git filter-branch  --force --index-filter "git rm -rf --cached --ignore-unmatch $1" --prune-empty --tag-name-filter cat -- --all

        # 删除 original 文件夹
        git for-each-ref --format='delete %(refname)' refs/original | git update-ref --stdin
        rm -rf .git/refs/original/
        # 修剪旧的 reflog 条目
        git reflog expire --expire=now --all
        # 验证数据库中对象的连接性和有效性
        git fsck --full --unreachable
        # 打包解压缩的对象，删除冗余的对象
        git repack -A -d
        # 清理不必要的文件并优化本地存储库
        git gc --aggressive --prune=now
    fi
}

alias gclean='git gc --aggressive --prune=now'

alias gabandon='git checkout . && git clean -xdf'

